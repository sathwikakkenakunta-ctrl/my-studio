{
  "cleanUrls": true,
  "redirects": [
    { "source": "/case-studies", "destination": "/projects", "permanent": true },
    { "source": "/case-studies/:slug", "destination": "/project/:slug", "permanent": true }
  ],
  "headers": [
    { "source": "/assets/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }] },
    { "source": "/projects/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=604800, stale-while-revalidate=86400" }] },
    { "source": "/(.*)", "headers": [
      { "key": "X-Content-Type-Options", "value": "nosniff" },
      { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
      { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
    ] }
  ],
  "rewrites": [{ "source": "/(.*)", "destination": "/index.html" }]
}
